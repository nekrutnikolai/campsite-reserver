[Unit]
Description=Campsite Availability Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/campsite-monitor
ExecStart=/home/pi/campsite-monitor/venv/bin/python -m campsite_monitor --dates YYYY-MM-DD:YYYY-MM-DD --interval 60
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
